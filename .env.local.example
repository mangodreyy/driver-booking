# WhatsApp number to send bookings to (with country code, no + or spaces)
# Example for Malaysia: 60123456789
WHATSAPP_NUMBER=60123456789

# Random secret to protect the cron endpoint — generate any long random string
CRON_SECRET=replace_with_a_random_secret_string

# Admin panel password (protects /admin page)
ADMIN_PASSWORD=your-strong-admin-password

# Staff access token — share this link with staff: https://yourapp.vercel.app/?token=VALUE
# Leave empty to disable token protection (dev mode)
STAFF_ACCESS_TOKEN=your-staff-token
